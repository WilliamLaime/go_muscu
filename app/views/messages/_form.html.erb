<%= simple_form_for [chat, message] do |f| %>
  <div class="chat-input-wrapper">
    <%= f.input :content,
        as: :string,
        label: false,
        required: true,
        placeholder: "Par où dois-je commencer...",
        wrapper_html: { class: "chat-input-field" },
        input_html: { class: "form-control" } %>
    <%= f.button :submit, "Go Muscu →", class: "btn-muscu-chat" %>
  </div>
<% end %>
