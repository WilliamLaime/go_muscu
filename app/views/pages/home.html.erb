<!-- HERO + DISCOVER TITLE (combined, 2-column layout) -->
<div class="page-hero">
  <div class="container page-hero__inner">

    <!-- LEFT: hero text (on purple) + discover title (on white below) -->
    <div class="page-hero__left">
      <div class="page-hero__text">
        <p class="hero__subtitle">Découvrez votre assistant personnel</p>
        <%= image_tag "logo_noir_gomuscu_big.png", class: "hero__logo", alt: "GoMuscu" %>
        <p class="hero__description">
          Grâce à ses conseils personnalisés mettez-vous<br>au sport sans attendre et à votre rythme.
        </p>
        </div>

      <div class="page-hero__discover">
        <h2>
          Découvrez différents<br>
          <span>programmes</span>
        </h2>
      </div>
    </div>

    <!-- RIGHT: large image spanning both zones -->
    <div class="page-hero__image">
      <%= image_tag "IA-coach-sport.jpg", alt: "AI Coach Sport" %>
    </div>

  </div>
</div>

<!-- PROGRAMS: grid only -->
<div class="programs">
  <div class="container">

    <% program_images = ["lower.jpg", "full_body.jpg", "leg.jpg", "push.jpg", "pull.jpg", "full_body.jpg"] %>
    <% program_descs  = [
      "Séance dédiée au bas du corps : quadriceps, ischios, fessiers et mollets.",
      "Entraînement des muscles de poussée : pectoraux, épaules et triceps.",
      "Travail des muscles de tirage : dos, biceps et arrière des épaules.",
      "Entraînement complet du haut du corps : poitrine, dos, épaules et bras.",
      "Séance ciblée sur le bas du corps : jambes et fessiers.",
      "Entraînement complet sollicitant l’ensemble des groupes musculaires."
    ] %>

    <div class="program-grid">
      <% @programs.each_with_index do |program, i| %>
        <%= link_to program_path(program), class: "program-card" do %>


          <div class="program-card__img-wrap">
            <%= cl_image_tag program.image.key, alt: program.workout %>
          </div>

          <div class="program-card__body">
            <h4><%= program.workout %></h4>
            <p><%= program_descs[i % program_descs.length] %></p>
          </div>

        <% end %>
      <% end %>
    </div>

  </div>
</div>

<!-- REVIEWS -->
<div class="reviews">
  <div class="container">
    <h3 class="reviews__title">Nos derniers avis utilisateurs</h3>

    <div class="review-grid">
      <%
        reviews = [
          {
            name: "Camille Lefèvre",
            avatar: "https://randomuser.me/api/portraits/women/68.jpg",
            filled: 5,
            text: "Programme super clair et facile à suivre. En 3 semaines, j’ai déjà gagné en force et en régularité.",
            date: "18 décembre"
          },
          {
            name: "Nicolas Martin",
            avatar: "https://randomuser.me/api/portraits/men/32.jpg",
            filled: 4,
            text: "Très bonne app : les séances sont bien structurées et rapides à lancer. J’aimerais juste plus d’exercices guidés en vidéo.",
            date: "4 janvier"
          },
          {
            name: "Sofia Benali",
            avatar: "https://randomuser.me/api/portraits/women/12.jpg",
            filled: 5,
            text: "J’adore le suivi et la progression. L’interface est clean et ça motive vraiment à ne pas lâcher.",
            date: "22 février"
          }
        ]
      %>

      <% reviews.each do |review| %>
        <div class="review-card">
          <div class="review-card__header">
            <img class="review-avatar" src="<%= review[:avatar] %>" alt="Utilisateur">
            <div>
              <p class="review-name"><%= review[:name] %></p>
            </div>
          </div>

          <div class="stars">
            <% 5.times do |s| %>
              <span class="star <%= s < review[:filled] ? '' : 'star--empty' %>">★</span>
            <% end %>
          </div>

          <p class="review-text">
            <%= review[:text] %>
          </p>

          <span class="review-date"><%= review[:date] %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>
