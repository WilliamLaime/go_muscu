<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Go Muscu" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Go Muscu">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <%= render "shared/navbar" %>
    <%= render "shared/flashes" %>

    <main id="main-content" class="flex-grow-1">
      <%= yield %>
      <p class="alert"><%= alert %></p>
      <p class="notice d-none"><%= notice %></p>
    </main>

    <%= render "shared/footer" %>


    <script>
      // <!-- Suggestion dans chat vide -->
      function fillInput(text) {
      const input = document.querySelector("#message_content");
      const form = input?.closest("form");
        if (input && form) {
          input.value = text;
          form.requestSubmit();
  }
}

     // <!-- Alerte qui disparait -->
    document.addEventListener("turbo:load", function() {
      setTimeout(function() {
        document.querySelectorAll(".alert").forEach(function(alert) {
          alert.classList.remove("show");
          setTimeout(() => alert.remove(), 300);
        });
      }, 3000);
    });

    // <!-- Bouton to the top qui reste au dessus footer -->
    document.addEventListener("turbo:load", function() {
      const btn = document.querySelector(".scroll-top-btn");
      if (!btn) return;

      const footer = document.querySelector("footer");
      if (!footer) return;

      window.addEventListener("scroll", function() {
        const footerTop = footer.getBoundingClientRect().top;
        const windowHeight = window.innerHeight;

        if (footerTop < windowHeight) {
          // Le footer est visible, on remonte le bouton
          btn.style.bottom = (windowHeight - footerTop + 16) + "px";
        } else {
          // Position normale
          btn.style.bottom = "32px";
        }
      });
});
    </script>
  </body>
</html>
