<div class="container-fluid">
  <div class="row" data-controller="toggle">

    <!-- LEFT SIDEBAR -->
    <div class="col-md-2 sidebar pt-3" data-toggle-target="hideable">
      <%= render "shared/sidenav", programs: @programs %>
    </div>

    <!-- MAIN CONTENT -->
    <div class="col-md-7" data-toggle-target="mainContent">
          <%= link_to "#", class: "d-none nav-link text-dark",
                  data: { action: "click->toggle#call", toggle_target: "show" } do %>
        <i class="fa-regular fa-square-caret-right"></i>
      <% end %>
      <h1><%= @program.workout %></h1>
      <%= @program.description %>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="col-md-3">
      <h2>Chats</h2>
      <%= button_to "New chat", program_chats_path(@program), class: "btn btn-primary mb-3" %>

      <% if @chats.any? %>
        <ul>
          <% @chats.each do |chat| %>
            <li><%= link_to chat.title, chat_path(chat) %></li>
          <% end %>
        </ul>
      <% else %>
        <p>There are no chats yet.</p>
      <% end %>
    </div>

  </div>
</div>
