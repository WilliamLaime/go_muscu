<div class="program-page">
  <div class="container-fluid">
    <div class="row g-4" data-controller="toggle">

      <!-- COL 1 : Menu / Sidebar -->
      <div class="col-md-3" data-toggle-target="sidebarCol">
        <aside class="sidebar" data-toggle-target="hideable">
          <div class="panel panel--sticky">
            <div class="panel__header panel__header--row">
              <span class="panel__title">Programmes</span>

              <%= link_to "#",
                class: "btn btn-sm btn-outline-secondary",
                data: { action: "click->toggle#call" } do %>
                <i class="fa-regular fa-square-caret-left"></i>
              <% end %>
            </div>

            <%= render "shared/sidenav", programs: @programs %>
          </div>
        </aside>

        <%= link_to "#",
          class: "btn btn-sm btn-outline-secondary d-none",
          data: { action: "click->toggle#call", toggle_target: "show" } do %>
          <i class="fa-regular fa-square-caret-right"></i> Menu
        <% end %>
      </div>

      <!-- COL 2 : Contenu programme -->
      <section class="col-md-6" data-toggle-target="mainContent">
        <div class="panel">
          <div class="panel__body">
            <p class="program-kicker">Programme</p>
            <h1 class="program-title"><%= @program.workout %></h1>

            <% if @program.description.present? %>
              <%
                lines    = @program.description.strip.split("\n").map(&:strip).reject(&:empty?)
                sections = []
                current  = nil

                lines.each do |line|
                  # Header = ligne qui commence par un emoji Unicode
                  if line.match?(/\A\p{Emoji}/)
                    current = { header: line, items: [] }
                    sections << current
                  elsif current
                    current[:items] << line
                  else
                    # Texte introductif avant le premier emoji (ex: "Programme Legs")
                    sections << { header: nil, items: [line] }
                    current = sections.last
                  end
                end
              %>
              <div class="program-sections">
                <% sections.each do |section| %>
                  <div class="program-section">
                    <% if section[:header] %>
                      <p class="program-section__header"><%= section[:header] %></p>
                    <% end %>
                    <% if section[:items].length == 1 %>
                      <p class="program-section__text"><%= section[:items].first %></p>
                    <% elsif section[:items].length > 1 %>
                      <ul class="program-section__list">
                        <% section[:items].each do |item| %>
                          <li><%= item %></li>
                        <% end %>
                      </ul>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="program-desc">Choisis un chat à droite ou crée-en un pour démarrer.</p>
            <% end %>
          </div>
        </div>
        <div class="panel mt-4">
          <div class="panel__body">
            <h2 class="h5 mb-2">Conseil rapide</h2>
            <p class="text-muted mb-0">
              Démarre un chat et précise ton niveau, ton objectif et ton matériel pour une séance sur-mesure.
            </p>
          </div>
        </div>
      </section>

      <!-- RIGHT -->
      <aside class="col-md-3">
        <div class="panel panel--sticky">
          <div class="panel__header panel__header--row">
            <span class="panel__title">Chats</span>
            <%= button_to program_chats_path(@program), class: "btn-muscu-chat" do %>
              Coach IA
            <% end %>
          </div>

          <div class="panel__body">
            <% if @chats.any? %>
              <div class="list-group list-group-flush chats-list">
                <% @chats.each do |chat| %>
                  <%= link_to chat.title, chat_path(chat), class: "list-group-item list-group-item-action" %>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted mb-0">There are no chats yet.</p>
            <% end %>
          </div>
        </div>
      </aside>

    </div>
  </div>
</div>
