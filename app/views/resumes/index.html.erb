<div class="container mt-4">
  <h1>Mon Dashboard</h1>

  <% if @resumes.empty? %>
    <p>Aucun chat sauvegardé pour l'instant.</p>
  <% else %>
    <% @resumes.each do |resume| %>
      <div class="card mb-4" style="background-color: white; border-radius: 8px;">
        <div class="card-body">
          <h5 class="card-title"><%= resume.title %></h5>
          <div class="card-text">
            <%= simple_format(resume.description) %>
          </div>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
          <%= link_to "Voir le chat", chat_path(resume.chat), class: "btn btn-sm btn-outline-primary" %>
          <%= button_to "Supprimer cette séance", resume_path(resume),
                method: :delete,
                data: { confirm: "Supprimer cette séance ?" },
                class: "btn btn-sm btn-danger" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
